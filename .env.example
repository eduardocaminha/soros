# ============================================================
# soros — variáveis de ambiente
# Copie para .env e preencha. Nunca commite o .env.
# ============================================================

# ------------------------------------------------------------
# Credenciais de exchange
# Necessárias apenas quando CRYPTO_LIVE=true / STOCKS_LIVE=true
# ------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_SECRET=

ALPACA_API_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ------------------------------------------------------------
# Toggles de execução — default OFF (paper trading)
# AVISO: mude para true somente após 48h+ de paper validado
#
# ATENÇÃO: estas chaves são PERMANENTEMENTE TRAVADAS — não podem ser
# alteradas pelo dashboard em runtime. Mudar exige editar o .env e
# reiniciar o bot. Isso é intencional: execução real exige decisão deliberada.
# ------------------------------------------------------------
CRYPTO_LIVE=false
STOCKS_LIVE=false
SENTIMENT_ENABLED=false

# ------------------------------------------------------------
# Símbolos e universo autônomo
# CRYPTO_SYMBOLS é override opcional: vazio (default) = universo decidido 100%
# por regra (market cap + gem scanner). Preencha para fixar símbolos adicionais.
# Vazio = cripto-only (default para STOCK_SYMBOLS). Preencha para operar ações.
# ------------------------------------------------------------
CRYPTO_SYMBOLS=
STOCK_SYMBOLS=

# Watchlist — só usada quando SCREENER_ENABLED=true
# Exemplo: CRYPTO_WATCHLIST=DOGE/USDT,ADA/USDT,MATIC/USDT
CRYPTO_WATCHLIST=
# Exemplo: STOCK_WATCHLIST=TSLA,AMZN,META
STOCK_WATCHLIST=

# ------------------------------------------------------------
# Universo autônomo — base por market cap (CoinGecko, keyless)
# ------------------------------------------------------------
MARKETCAP_TOP_N=20
MARKETCAP_REFRESH_SECS=3600

# ------------------------------------------------------------
# Gem scanner — candidatos de ignição (ccxt.fetch_tickers)
# ------------------------------------------------------------
# Volume surge: um símbolo precisa de >= N× o volume médio para qualificar
GEM_VOLUME_SURGE_MULTIPLIER=2.0
# Rate-of-change mínimo (%) na janela curta para qualificar como gem
GEM_ROC_MIN_PCT=3.0
# Máximo de gems por ciclo
GEM_TOP_N=5
# Piso de liquidez (USD 24h) para um candidato gem
GEM_MIN_VOLUME_USD=500000

# ------------------------------------------------------------
# Sinal de ignição
# Peso no composite (0.0 = desabilitado). Ajuste junto com CRYPTO_SIGNAL_WEIGHTS.
# ------------------------------------------------------------
IGNITION_WEIGHT=0.15

# ------------------------------------------------------------
# Risco para gems — tamanho de posição + trailing stop
# GEM_POSITION_SIZE_PCT: fração do equity por posição gem (deve ser <= POSITION_SIZE_PCT)
# GEM_TRAILING_STOP_PCT: distância do trailing stop (fração, ex: 0.05 = 5%). 0.0 = desabilitado.
# ------------------------------------------------------------
GEM_POSITION_SIZE_PCT=0.05
GEM_TRAILING_STOP_PCT=0.05

# ------------------------------------------------------------
# Screener
# Quando false (default): opera apenas os pinned
# Quando true: ranqueia pinned ∪ watchlist e seleciona top-N
# ------------------------------------------------------------
SCREENER_ENABLED=false
SCREENER_TOP_N=3
SCREENER_MIN_VOLUME_USD=1000000

# ------------------------------------------------------------
# Docker — Claude (opcional, apenas no container)
# Sem este token o sentimento usa a base keyless (Fear & Greed + CoinGecko votes)
# e o bot roda normalmente. Com ele, debates bull/bear usam a subscription.
# Copie de ~/.claude/.credentials.json → .oauth_token após autenticar.
# ------------------------------------------------------------
CLAUDE_CODE_OAUTH_TOKEN=

# ------------------------------------------------------------
# Fontes de sentimento (chaves opcionais)
# Cripto: sentimento keyless via CoinGecko (Fear & Greed + votes)
# Ações: Finnhub requer chave; sem chave → score neutro
# ------------------------------------------------------------
FINNHUB_API_KEY=

# ------------------------------------------------------------
# Coleta de dados
# ------------------------------------------------------------
WATCHLIST_OHLCV_LIMIT=50
LOOP_INTERVAL_SECONDS=3600

# ------------------------------------------------------------
# Capital e custos
# ------------------------------------------------------------
INITIAL_CAPITAL=10000
FEE_PCT=0.001
SLIPPAGE_PCT=0.0005
POSITION_SIZE_PCT=0.10

# ------------------------------------------------------------
# Logging e storage
# ------------------------------------------------------------
LOG_LEVEL=INFO
# DB_PATH local (dev). No container, docker-compose.yml força /data/soros.db.
DB_PATH=data/soros.db

# ------------------------------------------------------------
# Sweep de parâmetros (robustez) — comando on-demand, nunca no page load
#
# Grid de valores para o sweep de SIGNAL_THRESHOLD (ou outro parâmetro via --param).
# Enquadramento: robustez (estabilidade na vizinhança do valor atual),
# não "pegar o maior retorno histórico" (isso seria overfitting).
#
# Uso:
#   python -m backtest.sweep --symbols BTC/USDT:crypto --start 2024-01-01 --end 2024-12-31
#   python -m backtest.sweep --screener --start 2024-01-01 --end 2024-12-31 --thresholds 0.10,0.20,0.30
#   python -m backtest.sweep --symbols BTC/USDT:crypto --start 2024-01-01 --end 2024-12-31 \
#       --param position_size_pct --thresholds 0.05,0.10,0.15,0.20
#
# Resultado disponível no dashboard (/sweep) — marcando o valor atualmente em uso.
# ------------------------------------------------------------
SWEEP_THRESHOLDS=0.15,0.20,0.25,0.30,0.35

# ------------------------------------------------------------
# Nota: configuração em tempo real (Settings)
#
# As variáveis abaixo também podem ser ajustadas sem restart via
# o dashboard (aba Settings > PUT /api/settings/:key). O bot relê
# esses overrides no início de cada ciclo.
#
# Precedência: env var > tabela settings > default hardcoded
#
# Variáveis com override runtime disponível:
#   LOOP_INTERVAL_SECONDS, SIGNAL_THRESHOLD, DEBATE_DIVERGENCE_THRESHOLD,
#   SCREENER_ENABLED, SCREENER_TOP_N, SCREENER_MIN_VOLUME_USD,
#   MARKETCAP_TOP_N, MARKETCAP_REFRESH_SECS, DEX_BOOST_MULTIPLIER,
#   DEX_SCAN_CACHE_SECS, GEM_VOLUME_SURGE_MULTIPLIER, GEM_ROC_MIN_PCT,
#   GEM_TOP_N, GEM_MIN_VOLUME_USD, IGNITION_WEIGHT, GEM_POSITION_SIZE_PCT,
#   GEM_TRAILING_STOP_PCT, POSITION_SIZE_PCT, WATCHLIST_OHLCV_LIMIT,
#   SENTIMENT_MAX_AGE_SECONDS, INITIAL_CAPITAL, FEE_PCT, SLIPPAGE_PCT
#
# Permanentemente travadas (nunca editáveis via dashboard):
#   CRYPTO_LIVE, STOCKS_LIVE, SENTIMENT_ENABLED,
#   MAX_DRAWDOWN_PCT, MAX_OPEN_POSITIONS
# ------------------------------------------------------------
