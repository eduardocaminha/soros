# ============================================================
# soros — variáveis de ambiente
# Copie para .env e preencha. Nunca commite o .env.
# ============================================================

# ------------------------------------------------------------
# Credenciais de exchange
# Necessárias apenas quando CRYPTO_LIVE=true / STOCKS_LIVE=true
# ------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_SECRET=

ALPACA_API_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ------------------------------------------------------------
# Toggles de execução — default OFF (paper trading)
# AVISO: mude para true somente após 48h+ de paper validado
# ------------------------------------------------------------
CRYPTO_LIVE=false
STOCKS_LIVE=false
SENTIMENT_ENABLED=false

# ------------------------------------------------------------
# Símbolos e universo autônomo
# CRYPTO_SYMBOLS é override opcional: vazio (default) = universo decidido 100%
# por regra (market cap + gem scanner). Preencha para fixar símbolos adicionais.
# Vazio = cripto-only (default para STOCK_SYMBOLS). Preencha para operar ações.
# ------------------------------------------------------------
CRYPTO_SYMBOLS=
STOCK_SYMBOLS=

# Watchlist — só usada quando SCREENER_ENABLED=true
# Exemplo: CRYPTO_WATCHLIST=DOGE/USDT,ADA/USDT,MATIC/USDT
CRYPTO_WATCHLIST=
# Exemplo: STOCK_WATCHLIST=TSLA,AMZN,META
STOCK_WATCHLIST=

# ------------------------------------------------------------
# Universo autônomo — base por market cap (CoinGecko, keyless)
# ------------------------------------------------------------
MARKETCAP_TOP_N=20
MARKETCAP_REFRESH_SECS=3600

# ------------------------------------------------------------
# Gem scanner — candidatos de ignição (ccxt.fetch_tickers)
# ------------------------------------------------------------
# Volume surge: um símbolo precisa de >= N× o volume médio para qualificar
GEM_VOLUME_SURGE_MULTIPLIER=2.0
# Rate-of-change mínimo (%) na janela curta para qualificar como gem
GEM_ROC_MIN_PCT=3.0
# Máximo de gems por ciclo
GEM_TOP_N=5
# Piso de liquidez (USD 24h) para um candidato gem
GEM_MIN_VOLUME_USD=500000

# ------------------------------------------------------------
# Sinal de ignição
# Peso no composite (0.0 = desabilitado). Ajuste junto com CRYPTO_SIGNAL_WEIGHTS.
# ------------------------------------------------------------
IGNITION_WEIGHT=0.15

# ------------------------------------------------------------
# Risco para gems — trailing stop
# Distância do trailing stop (fração, ex: 0.05 = 5%). 0.0 = desabilitado.
# ------------------------------------------------------------
GEM_TRAILING_STOP_PCT=0.05

# ------------------------------------------------------------
# Screener
# Quando false (default): opera apenas os pinned
# Quando true: ranqueia pinned ∪ watchlist e seleciona top-N
# ------------------------------------------------------------
SCREENER_ENABLED=false
SCREENER_TOP_N=3
SCREENER_MIN_VOLUME_USD=1000000

# ------------------------------------------------------------
# Fontes de sentimento (chaves opcionais)
# Cripto: sentimento keyless via CoinGecko (Fear & Greed + votes)
# Ações: Finnhub requer chave; sem chave → score neutro
# ------------------------------------------------------------
FINNHUB_API_KEY=

# ------------------------------------------------------------
# Coleta de dados
# ------------------------------------------------------------
WATCHLIST_OHLCV_LIMIT=50
LOOP_INTERVAL_SECONDS=3600

# ------------------------------------------------------------
# Capital e custos
# ------------------------------------------------------------
INITIAL_CAPITAL=10000
FEE_PCT=0.001
SLIPPAGE_PCT=0.0005
POSITION_SIZE_PCT=0.10

# ------------------------------------------------------------
# Logging e storage
# ------------------------------------------------------------
LOG_LEVEL=INFO
DB_PATH=data/soros.db
